# Tradovate
TRADOVATE_USERNAME=
TRADOVATE_PASSWORD=
TRADOVATE_DEVICE_ID=
TRADOVATE_APP_ID=MNQ Zone Bot
TRADOVATE_APP_VERSION=0.1.0
TRADOVATE_CID=0
TRADOVATE_SEC=
TRADOVATE_ENV=demo
TRADOVATE_ACCOUNT_ID=0

# Webhook
WEBHOOK_SECRET=change-me-to-a-long-random-string

# Risk
RISK_PER_TRADE_USD=50
MNQ_POINT_VALUE=2.0
MAX_CONCURRENT_POSITIONS=1
MAX_ARMED_ORDERS=3
DAILY_LOSS_LIMIT_USD=200

# Behavior
DRY_RUN=true
TIF_OVERRIDE_GTC=false
# Test-only: skip all guardrail checks (session, max concurrent, max armed, daily loss).
# Set true when hand-firing alerts outside market hours. NEVER set true in live trading.
BYPASS_GUARDRAILS=false

# Storage
DB_PATH=bot.db

# MCP-driven zone poller (FALLBACK path; primary is the Pine alerter via webhook)
POLLER_ENABLED=false
POLL_INTERVAL_SEC=60
MCP_SERVER_CMD=node src/server.js
MCP_SERVER_CWD=/Users/simone/Git/tradingview-mcp
CHART_SYMBOL_MATCH=MNQ
CHART_TIMEFRAME=240
ZONE_WITHIN_POINTS=400

# Server
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO
